-- =====================================================
-- Data Quality Validation: {{ rule_name }}
-- Dataset: {{ dataset_name }}
-- Column: {{ column_name }}
-- =====================================================

SELECT
    '{{ dataset_name }}'      AS dataset,
    '{{ rule_name }}'         AS rule,
    '{{ column_name }}'       AS column,
    COUNT(*)                  AS total_count,
    SUM(
        CASE
            WHEN {{ column_name }} IS NULL THEN 1
            ELSE 0
        END
    )                          AS invalid_count
FROM {{ table_name }};
